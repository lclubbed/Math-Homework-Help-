<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Math Homework Help</title>
  <style>
    :root {
      --bg: #f4efe6;
      --panel: #fffaf2;
      --panel-strong: #ffffff;
      --ink: #1f2937;
      --muted: #6b7280;
      --accent: #d97706;
      --accent-dark: #9a3412;
      --line: #eadfcf;
      --shadow: 0 18px 40px rgba(92, 63, 28, 0.12);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: "Trebuchet MS", Verdana, sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(217, 119, 6, 0.16), transparent 30%),
        radial-gradient(circle at bottom right, rgba(14, 116, 144, 0.14), transparent 28%),
        linear-gradient(160deg, #f8f2e8 0%, #f3eadb 100%);
      min-height: 100vh;
      padding: 24px;
    }

    .app {
      max-width: 1120px;
      margin: 0 auto;
    }

    .hero {
      background: linear-gradient(135deg, rgba(255, 250, 242, 0.96), rgba(255, 244, 226, 0.92));
      border: 1px solid rgba(234, 223, 207, 0.9);
      border-radius: 28px;
      box-shadow: var(--shadow);
      padding: 28px;
      margin-bottom: 24px;
    }

    .hero h1 {
      margin: 0 0 8px;
      font-size: clamp(2rem, 4vw, 3.4rem);
      line-height: 1.05;
      color: var(--accent-dark);
    }

    .hero p {
      margin: 0;
      max-width: 700px;
      color: var(--muted);
      font-size: 1.05rem;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
    }

    .card {
      background: rgba(255, 250, 242, 0.95);
      border: 1px solid var(--line);
      border-radius: 22px;
      box-shadow: var(--shadow);
      padding: 22px;
    }

    .card h2 {
      margin-top: 0;
      margin-bottom: 8px;
      color: var(--accent-dark);
      font-size: 1.35rem;
    }

    .card p {
      color: var(--muted);
      margin-top: 0;
    }

    label {
      display: block;
      margin: 12px 0 6px;
      font-weight: 700;
      font-size: 0.95rem;
    }

    input,
    select,
    button {
      width: 100%;
      border-radius: 12px;
      border: 1px solid #d7c6ac;
      padding: 12px 14px;
      font-size: 1rem;
    }

    input,
    select {
      background: var(--panel-strong);
    }

    button {
      margin-top: 14px;
      background: linear-gradient(135deg, var(--accent), #f59e0b);
      color: white;
      border: none;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
      box-shadow: 0 10px 22px rgba(217, 119, 6, 0.22);
    }

    button:hover {
      transform: translateY(-1px);
      box-shadow: 0 14px 26px rgba(217, 119, 6, 0.28);
    }

    .result {
      margin-top: 14px;
      min-height: 48px;
      border-radius: 14px;
      background: #fff;
      border: 1px dashed #d8c8b2;
      padding: 12px;
      font-weight: 700;
    }

    .graph-panel {
      grid-column: 1 / -1;
    }

    canvas {
      width: 100%;
      max-width: 100%;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 18px;
      margin-top: 14px;
    }

    .hint {
      font-size: 0.9rem;
      color: var(--muted);
    }

    @media (max-width: 640px) {
      body {
        padding: 16px;
      }

      .hero,
      .card {
        padding: 18px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <section class="hero">
      <h1>Math Homework Help</h1>
      <p>Use this page to solve basic math, geometry, square roots, graphs, and trigonometry problems in one place.</p>
    </section>

    <section class="grid">
      <div class="card">
        <h2>Basic Calculator</h2>
        <p>Add, subtract, multiply, or divide two numbers.</p>

        <label for="operation">Operation</label>
        <select id="operation">
          <option value="add">Addition</option>
          <option value="subtract">Subtraction</option>
          <option value="multiply">Multiplication</option>
          <option value="divide">Division</option>
        </select>

        <label for="num1">First Number</label>
        <input id="num1" type="number" placeholder="Enter the first number">

        <label for="num2">Second Number</label>
        <input id="num2" type="number" placeholder="Enter the second number">

        <button onclick="calculateBasic()">Calculate</button>
        <div class="result" id="basicResult">Your answer will show here.</div>
      </div>

      <div class="card">
        <h2>Geometry</h2>
        <p>Find the area of a circle, rectangle, or triangle.</p>

        <label for="shape">Shape</label>
        <select id="shape" onchange="updateGeometryFields()">
          <option value="circle">Circle</option>
          <option value="rectangle">Rectangle</option>
          <option value="triangle">Triangle</option>
        </select>

        <label for="geo1" id="geo1Label">Radius</label>
        <input id="geo1" type="number" placeholder="Enter a value">

        <label for="geo2" id="geo2Label" style="display: none;">Second Value</label>
        <input id="geo2" type="number" placeholder="Enter a second value" style="display: none;">

        <button onclick="calculateGeometry()">Calculate Geometry</button>
        <div class="result" id="geometryResult">Pick a shape and enter your values.</div>
      </div>

      <div class="card">
        <h2>Square Root</h2>
        <p>Find the square root of any positive number.</p>

        <label for="rootInput">Number</label>
        <input id="rootInput" type="number" placeholder="Enter a number">

        <button onclick="calculateSquareRoot()">Find Square Root</button>
        <div class="result" id="rootResult">Your square root result will show here.</div>
      </div>

      <div class="card">
        <h2>Trigonometry</h2>
        <p>Find sine, cosine, and tangent from an angle in degrees.</p>

        <label for="angleInput">Angle in Degrees</label>
        <input id="angleInput" type="number" placeholder="Enter an angle">

        <button onclick="calculateTrig()">Calculate Trig</button>
        <div class="result" id="trigResult">Trig values will show here.</div>
      </div>

      <div class="card graph-panel">
        <h2>Graphing</h2>
        <p>Graph a line using the equation <strong>y = mx + b</strong>.</p>

        <div class="grid">
          <div>
            <label for="slopeInput">Slope (m)</label>
            <input id="slopeInput" type="number" step="any" placeholder="Example: 2">
          </div>
          <div>
            <label for="interceptInput">Y-Intercept (b)</label>
            <input id="interceptInput" type="number" step="any" placeholder="Example: 1">
          </div>
        </div>

        <button onclick="drawGraph()">Draw Graph</button>
        <p class="hint">The graph shows x and y values from about -10 to 10.</p>
        <div class="result" id="graphResult">Enter a slope and y-intercept to draw a line.</div>
        <canvas id="graphCanvas" width="900" height="420"></canvas>
      </div>
    </section>
  </div>

  <script>
    function setResult(id, text) {
      document.getElementById(id).textContent = text;
    }

    function calculateBasic() {
      const op = document.getElementById("operation").value;
      const num1 = parseFloat(document.getElementById("num1").value);
      const num2 = parseFloat(document.getElementById("num2").value);

      if (Number.isNaN(num1) || Number.isNaN(num2)) {
        setResult("basicResult", "Please enter both numbers.");
        return;
      }

      let result;

      if (op === "add") result = num1 + num2;
      if (op === "subtract") result = num1 - num2;
      if (op === "multiply") result = num1 * num2;
      if (op === "divide") {
        if (num2 === 0) {
          setResult("basicResult", "You cannot divide by zero.");
          return;
        }
        result = num1 / num2;
      }

      setResult("basicResult", "Result: " + result);
    }

    function updateGeometryFields() {
      const shape = document.getElementById("shape").value;
      const geo1Label = document.getElementById("geo1Label");
      const geo2Label = document.getElementById("geo2Label");
      const geo2 = document.getElementById("geo2");

      if (shape === "circle") {
        geo1Label.textContent = "Radius";
        geo2Label.style.display = "none";
        geo2.style.display = "none";
      } else if (shape === "rectangle") {
        geo1Label.textContent = "Length";
        geo2Label.textContent = "Width";
        geo2Label.style.display = "block";
        geo2.style.display = "block";
      } else {
        geo1Label.textContent = "Base";
        geo2Label.textContent = "Height";
        geo2Label.style.display = "block";
        geo2.style.display = "block";
      }
    }

    function calculateGeometry() {
      const shape = document.getElementById("shape").value;
      const geo1 = parseFloat(document.getElementById("geo1").value);
      const geo2 = parseFloat(document.getElementById("geo2").value);

      if (Number.isNaN(geo1)) {
        setResult("geometryResult", "Please enter the first value.");
        return;
      }

      let area;
      let message;

      if (shape === "circle") {
        area = Math.PI * geo1 * geo1;
        message = "Circle area: " + area.toFixed(2);
      } else if (shape === "rectangle") {
        if (Number.isNaN(geo2)) {
          setResult("geometryResult", "Please enter both values for a rectangle.");
          return;
        }
        area = geo1 * geo2;
        message = "Rectangle area: " + area.toFixed(2);
      } else {
        if (Number.isNaN(geo2)) {
          setResult("geometryResult", "Please enter both values for a triangle.");
          return;
        }
        area = 0.5 * geo1 * geo2;
        message = "Triangle area: " + area.toFixed(2);
      }

      setResult("geometryResult", message);
    }

    function calculateSquareRoot() {
      const value = parseFloat(document.getElementById("rootInput").value);

      if (Number.isNaN(value)) {
        setResult("rootResult", "Please enter a number.");
        return;
      }

      if (value < 0) {
        setResult("rootResult", "Please enter a positive number or 0.");
        return;
      }

      setResult("rootResult", "Square root: " + Math.sqrt(value).toFixed(6));
    }

    function calculateTrig() {
      const angle = parseFloat(document.getElementById("angleInput").value);

      if (Number.isNaN(angle)) {
        setResult("trigResult", "Please enter an angle.");
        return;
      }

      const radians = angle * (Math.PI / 180);
      const sinValue = Math.sin(radians).toFixed(6);
      const cosValue = Math.cos(radians).toFixed(6);
      const tanRaw = Math.tan(radians);
      const tanValue = Math.abs(cosValue) < 0.000001 ? "undefined" : tanRaw.toFixed(6);

      setResult(
        "trigResult",
        "sin(" + angle + ") = " + sinValue + " | cos(" + angle + ") = " + cosValue + " | tan(" + angle + ") = " + tanValue
      );
    }

    function drawGraphAxes(ctx, width, height, scale) {
      const centerX = width / 2;
      const centerY = height / 2;

      ctx.clearRect(0, 0, width, height);

      ctx.strokeStyle = "#d6c4ad";
      ctx.lineWidth = 1;

      for (let x = 0; x <= width; x += scale) {
        ctx.beginPath();
        ctx.moveTo(x, 0);
        ctx.lineTo(x, height);
        ctx.stroke();
      }

      for (let y = 0; y <= height; y += scale) {
        ctx.beginPath();
        ctx.moveTo(0, y);
        ctx.lineTo(width, y);
        ctx.stroke();
      }

      ctx.strokeStyle = "#7c2d12";
      ctx.lineWidth = 2;

      ctx.beginPath();
      ctx.moveTo(centerX, 0);
      ctx.lineTo(centerX, height);
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(0, centerY);
      ctx.lineTo(width, centerY);
      ctx.stroke();
    }

    function drawGraph() {
      const slope = parseFloat(document.getElementById("slopeInput").value);
      const intercept = parseFloat(document.getElementById("interceptInput").value);
      const canvas = document.getElementById("graphCanvas");
      const ctx = canvas.getContext("2d");
      const width = canvas.width;
      const height = canvas.height;
      const scale = 40;

      if (Number.isNaN(slope) || Number.isNaN(intercept)) {
        setResult("graphResult", "Please enter both slope and y-intercept.");
        drawGraphAxes(ctx, width, height, scale);
        return;
      }

      drawGraphAxes(ctx, width, height, scale);

      ctx.strokeStyle = "#0f766e";
      ctx.lineWidth = 3;
      ctx.beginPath();

      let started = false;
      for (let pixelX = 0; pixelX <= width; pixelX += 1) {
        const graphX = (pixelX - width / 2) / scale;
        const graphY = slope * graphX + intercept;
        const pixelY = height / 2 - graphY * scale;

        if (!started) {
          ctx.moveTo(pixelX, pixelY);
          started = true;
        } else {
          ctx.lineTo(pixelX, pixelY);
        }
      }

      ctx.stroke();
      setResult("graphResult", "Graph drawn for y = " + slope + "x + " + intercept);
    }

    updateGeometryFields();
    drawGraph();
  </script>
</body>
</html>
